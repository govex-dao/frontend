{
  "name": "govex-frontend-public",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node -r ./scripts/crypto-hash-polyfill.cjs ./node_modules/vite/bin/vite.js build",
    "start": "serve dist -s -c serve.json -l tcp://0.0.0.0:${PORT:-3000}",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc -b && pnpm format:check && pnpm lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@govex/futarchy-sdk": "git+https://github.com/govex-dao/sdk-v3.git#33c29005cda826252a10464c2e66ed2b9e285e33",
    "@mysten/dapp-kit": "^0.19.8",
    "@mysten/move-bytecode-template": "^0.3.0",
    "@mysten/sui": "^1.44.0",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "5.90.12",
    "lightweight-charts": "^5.0.9",
    "lucide-react": "^0.552.0",
    "motion": "^12.23.24",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "npm:rolldown-vite@7.1.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "govex-sdk-v3"
    ],
    "overrides": {
      "vite": "npm:rolldown-vite@7.1.14",
      "@tanstack/react-query": "5.90.12",
      "@tanstack/query-core": "5.90.12",
      "minimatch@<3.1.3": "3.1.5",
      "minimatch@>=9.0.0 <9.0.6": "9.0.9",
      "flatted@<3.4.2": "3.4.2",
      "fast-uri": "3.1.2",
      "postcss": "8.5.10",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@<2.0.3": "2.0.3",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
